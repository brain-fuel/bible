{
  "book_id": "PSA",
  "chapter": 115,
  "source": "Swete 1909 (Public Domain)",
  "verses": [
    {
      "verse": 1,
      "greek_lxx": "Ἁλληλουιά. Ἐπίστευσα, διὸ ἐλάλησα· ἐγὼ δὲ ἐταπεινώθην σφόδρα.",
      "refs": {
        "mt": {
          "src": "116:10"
        }
      }
    },
    {
      "verse": 2,
      "greek_lxx": "ἐγὼ εἶπα ἐν τῇ ἐκστάσει μου Πᾶς ἄνθρωπος ψεύστης.",
      "refs": {
        "mt": {
          "src": "116:11"
        }
      }
    },
    {
      "verse": 3,
      "greek_lxx": "τί ἀνταποδώσω τῷ κυρίῳ περὶ ὧν ἀνταπέδωκέν μοι;",
      "refs": {
        "mt": {
          "src": "116:12"
        }
      }
    },
    {
      "verse": 4,
      "greek_lxx": "ποτήριον σωτηρίου λήμψομαι, καὶ τὸ ὄνομα Κυρίου ἐπικαλέσομαι.",
      "refs": {
        "mt": {
          "src": "116:13"
        }
      }
    },
    {
      "verse": 6,
      "greek_lxx": "τίμιος ἐναντίον Κυρίου ὁ θάνατος τῶν ὁσίων αὐτοῦ.",
      "refs": {
        "mt": {
          "src": "116:15"
        }
      }
    },
    {
      "verse": 7,
      "greek_lxx": "ὦ Κύριε, ἐγὼ δοῦλος σός, ἐγὼ δοῦλος σὸς καὶ υἱὸς τῆς παιδίσκης σου· διέρρηξας τοὺς δεσμούς μου.",
      "refs": {
        "mt": {
          "src": "116:16"
        }
      }
    },
    {
      "verse": 8,
      "greek_lxx": "σοὶ θύσω θυσίαν αἰνέσεως·",
      "refs": {
        "mt": {
          "src": "116:17"
        }
      }
    },
    {
      "verse": 9,
      "greek_lxx": "τὰς εὐχάς μου ἀποδώσω τῷ κυρίῳ ἐναντίον παντὸς τοῦ λαοῦ αὐτοῦ,",
      "refs": {
        "mt": {
          "src": "116:18"
        }
      }
    },
    {
      "verse": 10,
      "greek_lxx": "ἐν αὐλαῖς οἴκου Κυρίου, ἐν μέσῳ σου, Ἰερουσαλήμ.",
      "refs": {
        "mt": {
          "src": "116:19"
        }
      }
    }
  ]
}
